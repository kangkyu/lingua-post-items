{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "description": "Backend API server for Lingua Stagify",
  "scripts": {
    "dev": "node dev-server.js",
    "start": "node server.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
    "lint": "echo 'No lint configured for backend'",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:seed:simple": "node prisma/simple-seed.js",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "test": "dotenv -f .env.test -- vitest run"
  },
  "dependencies": {
    "@google-cloud/translate": "^9.3.0",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.x"
  }
}
